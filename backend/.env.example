# JWT 서명 키 — 프로덕션: openssl rand -hex 32
JWT_SECRET=

# RDS PostgreSQL 연결 문자열 — 비우면 인메모리 모드
DATABASE_URL=
# ElastiCache Redis 연결 문자열 — 비우면 인메모리 모드
REDIS_URL=
# CORS 허용 오리진 — 로컬: http://localhost:5173 / 프로덕션: https://nadaum.today
CORS_ORIGIN=

# 슈퍼관리자 계정 — 최초 부팅 시 없으면 자동 생성, 비우면 시드 건너뜀
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Google OAuth2 — Google Cloud Console에서 발급, 리디렉션 URI: ${BACKEND_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 서버 URL — 로컬: http://localhost:3000 / 프로덕션: https://nadaum.today
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# OpenAI 호환 게이트웨이 — OPENAI_BASE_URL 비우면 OpenAI 직접 호출
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-5-chat-latest

# Gemini 직통 — 입력 시 OpenAI 게이트웨이보다 우선
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.5-flash

# 임베딩(RAG) — mindlogic 게이트웨이 미지원, 지원 엔드포인트 전환 시 true
EMBEDDINGS_ENABLED=false

# AWS SES 보호자 이메일 알림 — 비우면 비활성, 프로덕션 액세스 후 입력
SES_FROM_EMAIL=
AWS_REGION=ap-northeast-2

# AWS SNS 보호자 SMS 알림
SMS_ALERTS_ENABLED=false
SMS_SENDER_ID=
