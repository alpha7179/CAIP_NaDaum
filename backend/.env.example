# JWT (프로덕션: 길고 무작위인 값으로 교체)
JWT_SECRET=

# ── 영속성 (있으면 프로덕션, 비우면 인메모리 데모) ──
# RDS PostgreSQL 연결 문자열. 예: postgres://USER:PASS@HOST:5432/nadaum?sslmode=require
DATABASE_URL=
# ElastiCache Redis 연결 문자열. 예: redis://HOST:6379  (TLS: rediss://HOST:6379)
REDIS_URL=
# CORS 허용 오리진(프론트 도메인). 예: https://app.example.com  (비우면 * )
CORS_ORIGIN=

# ── 슈퍼관리자(시드 관리자) 계정 ──
# 최초 부팅 시 이 계정이 없으면 자동 생성된다(is_admin=true). 이미 있으면 권한만 보장.
# 이 계정은 탈퇴·관리자 권한 회수가 불가능하도록 보호된다(adminProtection).
# 프로덕션(Pg): 반드시 강력한 ADMIN_PASSWORD를 지정할 것. 비우면 관리자 계정 시드를 건너뛴다(로그인 불가).
# 로컬 인메모리(개발/데모, DB 없음)에서는 편의상 비우면 기본값 'admin'이 적용된다.
# AWS 배포 시에는 Secrets Manager(NaDaum/APIKeys)에 저장되어 자동 주입된다.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Google OAuth2 — Google Cloud Console에서 발급
# https://console.cloud.google.com → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 노션 연동 — 사용자별 "내부 통합 토큰" 방식이라 앱 차원의 OAuth 자격증명이 필요 없다.
#   각 사용자가 https://www.notion.so/my-integrations 에서 본인 통합을 만들어 토큰을
#   발급받고, 저장할 페이지를 통합에 공유한 뒤, 앱의 공유 화면에서 토큰을 입력해 연결한다.
# 노션 사용자 액세스 토큰 at-rest 암호화 키(임의의 긴 문자열). 설정하면 DB의 토큰이
#   AES-256-GCM으로 암호화되어 저장된다. 비우면 평문 저장(개발/데모).
#   운영에서는 반드시 강력한 값을 Secrets Manager로 주입할 것. 키 분실 시 기존 토큰은
#   복호화 불가하므로 사용자는 노션을 재연결해야 한다.
NOTION_TOKEN_ENC_KEY=

# 서버 URL (로컬 개발)
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── 텍스트 AI — OpenAI 호환 게이트웨이(mindlogic 등) 경유 ──
# 게이트웨이 하나로 GPT·Gemini·Claude 등 여러 모델이 제공된다(키 없으면 결정적 Fake).
# Gemini 직통 경로는 기본 미사용 — 필요 시 GEMINI_API_KEY/GEMINI_BASE_URL/GEMINI_MODEL을
# 설정하면 직통 경로가 게이트웨이보다 우선된다.
OPENAI_API_KEY=
# OpenAI 호환 게이트웨이 엔드포인트 (선택 — Azure/프록시/호환 API. 비우면 기본 OpenAI)
# 예: https://factchat-cloud.mindlogic.ai/v1/gateway
OPENAI_BASE_URL=
# OpenAI 채팅 모델명 (선택 — 게이트웨이 허용 모델로 지정. 비우면 gpt-4o)
# 주의: gpt-5-mini 등 추론 모델은 빈 응답 가능 → 비추론 채팅 모델 권장
OPENAI_MODEL=gpt-5-chat-latest

# Gemini 직통 경로 (선택 — 설정 시 게이트웨이보다 우선. 비우면 미사용)
GEMINI_API_KEY=
GEMINI_BASE_URL=
GEMINI_MODEL=gemini-2.5-flash

# 임베딩(의미 기반 회상 RAG) — 기본 활성(OpenAI 키 있을 때 text-embedding-3-small 사용).
# 게이트웨이가 /embeddings를 제공하지 않으면 false로 설정해 낭비 호출을 막을 것
# (회상은 날짜 기반만 동작하며, 일기 저장·대화에는 영향 없음).
EMBEDDINGS_ENABLED=

# ── 보호자 안전 알림 이메일 (AWS SES) ──
# 고위험으로 대화가 강제 종료되고, 사용자가 '보호자 알림'에 동의한 경우,
# 등록된 보호자 이메일 전원에게 안전 안내가 발송된다(대화 내용 미포함).
# SES_FROM_EMAIL이 비어 있거나 DATABASE_URL이 없으면 알림은 비활성(외부 알림 0회).
# 발신 주소는 SES에서 사전 검증(verified identity)되어 있어야 한다.
SES_FROM_EMAIL=
# AWS 리전 (예: ap-northeast-2). 비우면 SDK 기본 자격증명 체인의 리전을 사용.
AWS_REGION=ap-northeast-2

# ── 보호자 안전 알림 SMS (AWS SNS) ──
# 고위험 강제 종료 + 보호자 알림 동의 + 사용자 SMS 설정 활성 시,
# 등록된 보호자 전화번호(E.164)로 짧은 안전 안내 SMS를 발송한다(대화 내용 미포함).
# SMS_ALERTS_ENABLED=true 이고 DATABASE_URL이 있을 때만 활성. AWS 자격증명/리전 필요.
SMS_ALERTS_ENABLED=false
# (선택) SMS 발신자 ID — 일부 국가에서만 적용. 한국은 사전 등록이 필요할 수 있음.
SMS_SENDER_ID=
