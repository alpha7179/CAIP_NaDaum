{
  "name": "@nadaum/shared",
  "version": "0.1.0",
  "private": true,
  "description": "「나,다움」 공유 타입 패키지 — 백엔드/프론트엔드 공통 타입 및 콘텐츠",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./content": {
      "types": "./dist/content/index.d.ts",
      "import": "./dist/content/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf dist",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "fast-check": "^3.19.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
