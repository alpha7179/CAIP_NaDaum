    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
