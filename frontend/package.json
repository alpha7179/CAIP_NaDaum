{
  "name": "@nadaum/frontend",
  "version": "0.1.0",
  "private": true,
  "description": "「나,다움」 프론트엔드 — React 18 + TypeScript (Vite)",
  "type": "module",
  "scripts": {
    "dev": "vite",
